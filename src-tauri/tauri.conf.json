{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SQL Prompt Copilot",
  "version": "0.1.0",
  "identifier": "com.sql-prompt-copilot.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SQL Prompt Copilot",
        "width": 720,
        "height": 480,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "center": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "startMenuFolder": "SQL Prompt Copilot"
      }
    }
  }
}
